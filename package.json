{
  "name": "lobsterjs",
  "version": "0.2.0",
  "description": "Extended Markdown parser for rich web pages",
  "private": false,
  "type": "module",
  "main": "./dist/lobster.js",
  "module": "./dist/lobster.js",
  "types": "./dist/lobster.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lobster.js",
      "types": "./dist/lobster.d.ts"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:docs": "vite build && cp dist/lobster.js docs/lobster.js"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
