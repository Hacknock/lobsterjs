{
  "name": "@hacknock/lobster",
  "version": "0.2.0",
  "description": "Extended Markdown parser for rich web pages",
  "private": false,
  "type": "module",
  "main": "./dist/lobster.node.cjs",
  "module": "./dist/lobster.node.js",
  "types": "./dist/index.node.d.ts",
  "exports": {
    ".": {
      "node": {
        "import": "./dist/lobster.node.js",
        "require": "./dist/lobster.node.cjs",
        "types": "./dist/index.node.d.ts"
      },
      "browser": {
        "import": "./dist/lobster.js",
        "types": "./dist/index.d.ts"
      },
      "default": {
        "import": "./dist/lobster.node.js",
        "require": "./dist/lobster.node.cjs",
        "types": "./dist/index.node.d.ts"
      }
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build && vite build --config vite.node.config.ts && tsc --emitDeclarationOnly --declaration --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:docs": "vite build && cp dist/lobster.js docs/lobster.js"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "packageManager": "pnpm@10.30.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "onFail": "error"
    }
  }
}
